#!/usr/bin/env bash
# Entry point: configure this as the custom shell command in your terminal
# emulator's profile settings.
#
# Each terminal tab maps 1-to-1 to a tmux window.  The trick is grouped
# sessions: one base session ("terminal-hud") owns all windows; each terminal
# tab gets its own lightweight session grouped with the base.  Grouped sessions
# share all windows but each tracks its own current window independently, so
# switching tabs never moves another tab's view.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Ensure the custom terminfo entry (tmux-256color + OSC 8 Hls/hle) is compiled
# before tmux starts — panes will inherit TERM=terminator-256color from
# default-terminal in tmux.conf and need the entry in the database from day 1.
_ti_src="$SCRIPT_DIR/terminfo/terminator-256color.ti"
_ti_dst="$HOME/.terminfo/t/terminator-256color"
if [ -f "$_ti_src" ] && [ ! -f "$_ti_dst" ]; then
    tic -x -o "$HOME/.terminfo" "$_ti_src" 2>/dev/null
fi
unset _ti_src _ti_dst

# Avoid nesting: if we're already inside tmux just run bash.
if [ -n "$TMUX" ]; then
    exec bash --rcfile "$SCRIPT_DIR/bash-init.sh"
fi

SESSION="terminal-hud"
SHELL_CMD="TERMINATOR_SHELL_DIR='$SCRIPT_DIR' bash --rcfile '$SCRIPT_DIR/bash-init.sh'"

if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux source-file "$SCRIPT_DIR/tmux.conf"
    # Inherit the CWD from the tab that had focus before this one opened.
    # tmux.conf records @last_focused_pane on every pane-focus-in event.
    # We read the bash PID for that pane and resolve its CWD directly from
    # /proc, bypassing #{pane_current_path} which can track the wrong process.
    _last_pane=$(tmux show-options -gqv @last_focused_pane 2>/dev/null)
    _pane_pid=$(tmux display-message -t "$_last_pane" -p "#{pane_pid}" 2>/dev/null)
    CWD=$(readlink "/proc/${_pane_pid}/cwd" 2>/dev/null)
    unset _last_pane _pane_pid
    # Create this tab's grouped session first (detached), then open a new
    # window inside it.  Grouped sessions have independent current-window
    # pointers, so new-window only advances THIS session's pointer — no race
    # with other tabs that may be opening at the same time.
    GROUPED=$(tmux new-session -d -t "$SESSION" -P -F "#{session_name}")
    tmux new-window -t "$GROUPED" ${CWD:+-c "$CWD"} "$SHELL_CMD"
    # Tag the window so bash-init.sh knows exactly which grouped session to
    # kill on exit — #{session_name} is unreliable because $TMUX in the shell
    # can point to the base session rather than the grouped one.
    tmux set-option -w -t "$GROUPED" @grouped_session "$GROUPED"
    exec tmux attach -t "$GROUPED"
else
    # First tab: create the base session detached (no terminal attached to it
    # directly — all clients connect via their own grouped sessions below).
    tmux -f "$SCRIPT_DIR/tmux.conf" new-session -d -s "$SESSION" "$SHELL_CMD"
    GROUPED=$(tmux new-session -d -t "$SESSION" -P -F "#{session_name}")
    # Tag window 0 (started under the base session, so $TMUX points there).
    FIRST_PANE=$(tmux display-message -t "$SESSION" -p "#{pane_id}")
    tmux set-option -w -t "$FIRST_PANE" @grouped_session "$GROUPED"
    exec tmux attach -t "$GROUPED"
fi
